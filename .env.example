# Browser-safe Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase configuration. Never prefix this value with NEXT_PUBLIC_.
# Use the new secret key from Supabase Dashboard > Project Settings > API.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Legacy fallback only, if your project has not yet migrated to a secret key.
# SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

